# Optional runtime/server configuration only. The default Python core never reads this file or
# process environment. Copy to .env for Compose or export selected names for local interfaces.
# Never commit a populated .env; Provider keys are caller/runtime-injected and never persisted.
LINGUASPINDLE_PORT=8765
LINGUASPINDLE_LOG_LEVEL=INFO
LINGUASPINDLE_WORKER_POLL_SECONDS=0.25
# Compatibility mode is the default. Set true for service-to-service deployments that require
# Idempotency-Key on every persistent or Provider-triggering POST operation.
LINGUASPINDLE_REQUIRE_IDEMPOTENCY_KEY=false

# Source and EPUB/CBZ archive guards. Values are bytes unless noted otherwise. Programmatic core
# callers pass TranslationOptions/ArchiveLimits explicitly instead of using these variables.
LINGUASPINDLE_MAX_UPLOAD_BYTES=104857600
LINGUASPINDLE_MAX_ARCHIVE_FILES=2000
LINGUASPINDLE_MAX_ARCHIVE_BYTES=1048576000
LINGUASPINDLE_MAX_ARCHIVE_MEMBER_BYTES=104857600
LINGUASPINDLE_MAX_ARCHIVE_COMPRESSION_RATIO=100
LINGUASPINDLE_MAX_ARCHIVE_PATH_DEPTH=20

# Optional OpenAI-compatible HTTP Provider ([openai] or [all] extra). Add [openai] alongside
# [server] when the server should call this Provider; [server] alone does not install HTTPX.
LINGUASPINDLE_OPENAI_BASE_URL=https://api.openai.com/v1
LINGUASPINDLE_OPENAI_API_KEY=
LINGUASPINDLE_OPENAI_MODEL=gpt-4.1-mini
LINGUASPINDLE_OPENAI_TIMEOUT_SECONDS=60
LINGUASPINDLE_OPENAI_CONCURRENCY=2
LINGUASPINDLE_OPENAI_MAX_RETRIES=3

# Optional separately operated manga-image-translator HTTP service ([manga] or [all] extra). Add
# [manga] alongside [server] when the server should call it; [server] alone does not install HTTPX.
LINGUASPINDLE_MIT_BASE_URL=
LINGUASPINDLE_MIT_TIMEOUT_SECONDS=600
LINGUASPINDLE_MIT_CONFIG_JSON={}

# Optional local runtime/server overrides.
# LINGUASPINDLE_DATA_DIR=./data
# LINGUASPINDLE_HOST=127.0.0.1
