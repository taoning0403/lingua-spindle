# Copy to .env for Docker Compose or export the same names for local execution.
# Never commit a populated .env file. LinguaSpindle reads Provider keys at runtime only.
LINGUASPINDLE_PORT=8765
LINGUASPINDLE_LOG_LEVEL=INFO

LINGUASPINDLE_OPENAI_BASE_URL=https://api.openai.com/v1
LINGUASPINDLE_OPENAI_API_KEY=
LINGUASPINDLE_OPENAI_MODEL=gpt-4.1-mini
LINGUASPINDLE_OPENAI_TIMEOUT_SECONDS=60
LINGUASPINDLE_OPENAI_CONCURRENCY=2
LINGUASPINDLE_OPENAI_MAX_RETRIES=3

# Optional separately operated manga-image-translator HTTP service.
LINGUASPINDLE_MIT_BASE_URL=
LINGUASPINDLE_MIT_TIMEOUT_SECONDS=600
LINGUASPINDLE_MIT_CONFIG_JSON={}

# Optional local overrides.
# LINGUASPINDLE_DATA_DIR=./data
# LINGUASPINDLE_HOST=127.0.0.1
# LINGUASPINDLE_MAX_UPLOAD_BYTES=104857600
# LINGUASPINDLE_MAX_ARCHIVE_FILES=2000
# LINGUASPINDLE_MAX_ARCHIVE_BYTES=1048576000
